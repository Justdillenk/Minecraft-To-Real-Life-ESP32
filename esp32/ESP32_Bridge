#include <WiFi.h>
#include <WebServer.h>

const char* ssid = "wifi_name";
const char* password = "wifi_passowrd";

WebServer server(80);

float health = 20.0;
float prevHealth = 20.0;
int hunger = 20;

#define BUZZER_PIN 13

void beepDamage() {
  digitalWrite(BUZZER_PIN, HIGH);
  delay(100);
  digitalWrite(BUZZER_PIN, LOW);
}

void beepCritical() {
  for (int i = 0; i < 3; i++) {
    digitalWrite(BUZZER_PIN, HIGH);
    delay(100);
    digitalWrite(BUZZER_PIN, LOW);
    delay(100);
  }
}

void handleUpdate() {
  if (server.hasArg("health") && server.hasArg("hunger")) {
    prevHealth = health;
    health = server.arg("health").toFloat();
    hunger = server.arg("hunger").toInt();

    Serial.printf("Health: %.1f/20  |  Hunger: %d/20\n", health, hunger);

    // Damage detected
    if (health < prevHealth) {
      Serial.println("Damage taken!");
      if (health <= 6) {
        Serial.println("Critical health!");
        beepCritical();
      } else {
        beepDamage();
      }
    }

    server.send(200, "text/plain", "OK");
  } else {
    server.send(400, "text/plain", "Missing args");
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(BUZZER_PIN, OUTPUT);
  digitalWrite(BUZZER_PIN, LOW);

  WiFi.begin(ssid, password);
  Serial.print("Connecting to WiFi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nConnected! IP: " + WiFi.localIP().toString());

  server.on("/update", handleUpdate);
  server.begin();
}

void loop() {
  server.handleClient();
}
